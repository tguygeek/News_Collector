# =============================================================
# NewsDigest — Configuration centrale
# =============================================================
# IMPORTANT : ne jamais committer ce fichier sur Git.
# Ajoute .env dans ton .gitignore si ce n'est pas déjà fait.
# Copie ce fichier en .env et remplis chaque valeur.
# =============================================================

# --- Groq API (résumé IA) ---
# Inscription gratuite : https://console.groq.com
GROQ_API_KEY=VOTRE_CLE_GROQ_ICI
GROQ_MODEL=llama-3.1-8b-instant

# --- GNews API (collecte articles) ---
# Inscription gratuite : https://gnews.io
GNEWS_API_KEY=VOTRE_CLE_GNEWS_ICI
GNEWS_MAX_ARTICLES=10

# --- Gmail SMTP ---
# Utiliser un mot de passe d'application, PAS ton vrai mot de passe.
# Activer : Compte Google > Sécurité > Mots de passe des applications
GMAIL_ADDRESS=ton.adresse@gmail.com
GMAIL_APP_PASSWORD=VOTRE_MOT_DE_PASSE_APP_GMAIL

# --- Telegram Bot ---
# Token  : ouvrir @BotFather sur Telegram > /newbot
# Chat ID : ouvrir @userinfobot sur Telegram > /start
TELEGRAM_BOT_TOKEN=VOTRE_TOKEN_BOT_TELEGRAM
TELEGRAM_CHAT_ID=VOTRE_CHAT_ID_TELEGRAM

# --- Pipeline ---
# Heure d'envoi du digest quotidien (format HH:MM)
DIGEST_SEND_TIME=07:00
# Minute de la collecte horaire (0-59)
COLLECT_MINUTE=15
# Canal d'envoi : both | email | telegram
SEND_CHANNEL=both

# --- Résumé IA ---
# Nombre max d'articles résumés par catégorie
TOP_N_PER_CATEGORY=3
# Délai entre appels Groq en secondes (évite le rate limit)
DELAY_BETWEEN_CALLS=2
